<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <radialGradient id="bg" cx="50%" cy="42%" r="75%">
      <stop offset="0%" stop-color="#2a0a10"/>
      <stop offset="55%" stop-color="#16060a"/>
      <stop offset="100%" stop-color="#0b0b10"/>
    </radialGradient>
    <linearGradient id="steel" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#e9eef6"/>
      <stop offset="45%" stop-color="#aeb8c6"/>
      <stop offset="100%" stop-color="#6c7686"/>
    </linearGradient>
    <linearGradient id="gold" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f6d98a"/>
      <stop offset="50%" stop-color="#e3a93a"/>
      <stop offset="100%" stop-color="#a9721c"/>
    </linearGradient>
    <linearGradient id="shield" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#9e1f26"/>
      <stop offset="100%" stop-color="#5e0f15"/>
