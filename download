  </defs>

  <rect width="512" height="512" rx="96" fill="url(#bg)"/>
  <circle cx="256" cy="226" r="186" fill="#ef4450" opacity="0.08"/>

  <!-- crossed swords behind the shield -->
  <g stroke-linecap="round">
    <g transform="rotate(45 256 256)">
      <rect x="248" y="78" width="16" height="300" rx="6" fill="url(#steel)"/>
      <polygon points="256,64 246,86 266,86" fill="#f4f7fb"/>
      <rect x="226" y="356" width="60" height="16" rx="6" fill="url(#gold)"/>
      <rect x="249" y="356" width="14" height="58" rx="6" fill="url(#gold)"/>
      <circle cx="256" cy="418" r="11" fill="url(#gold)"/>
    </g>
    <g transform="rotate(-45 256 256)">
      <rect x="248" y="78" width="16" height="300" rx="6" fill="url(#steel)"/>
      <polygon points="256,64 246,86 266,86" fill="#f4f7fb"/>
      <rect x="226" y="356" width="60" height="16" rx="6" fill="url(#gold)"/>
      <rect x="249" y="356" width="14" height="58" rx="6" fill="url(#gold)"/>
      <circle cx="256" cy="418" r="11" fill="url(#gold)"/>
    </g>
  </g>

  <!-- heater shield -->
  <path d="M256 150
           L370 188
           Q370 320 256 384
           Q142 320 142 188 Z"
        fill="url(#shield)" stroke="url(#gold)" stroke-width="12" stroke-linejoin="round"/>
  <path d="M256 150 L370 188 Q370 320 256 384 Z" fill="#000" opacity="0.16"/>

  <!-- emblem: a bold chevron + crown dot -->
